{
  "command": {
    "name": "work",
    "description": "Project-specific Paperclip cockpit.",
    "register_pc_fallback": false
  },
  "gateway": {
    "reset_on_gateway_shutdown": false,
    "reset_session_age_minutes": 0,
    "reset_idle_minutes": 0
  },
  "hooks": {
    "after_move": {
      "auto_finalize_parents_on_statuses": ["done", "blocked", "cancelled"]
    }
  },
  "notifications": {
    "comments": {
      "move_status_changed": "Status changed via cockpit: {old_status} -> {new_status}.",
      "auto_finalized": "Automatically finalized: all visible child issues are in terminal statuses."
    }
  },
  "company_hints": ["Example Workspace"],
  "labels": {
    "company": "workspace",
    "companies": "workspaces",
    "agent": "member",
    "agents": "members",
    "task": "item",
    "tasks": "items",
    "comment": "note",
    "comments": "notes"
  },
  "terms": {
    "companies": "workspaces",
    "agents": "members",
    "tasks": "items",
    "task": "item",
    "comments": "notes",
    "move": "move",
    "health": "health",
    "status": "overview",
    "capabilities": "capabilities",
    "debug": "debug"
  },
  "aliases": {
    "agents": ["members", "team", "people"],
    "tasks": ["items", "queue", "work"],
    "task": ["item"],
    "comments": ["notes"]
  },
  "markers": ["paperclip", "work"],
  "presentation": {
    "mode": "human",
    "language": "en",
    "home": {
      "intro": "Connected to the project workspace in Paperclip.",
      "items": [
        { "action": "status", "text": "short workspace overview" },
        { "action": "agents", "text": "show members" },
        { "action": "tasks", "text": "show open items" }
      ],
      "more": [
        { "command": "help full", "text": "technical help" },
        { "action": "debug", "text": "diagnostics" }
      ]
    },
    "limits": {
      "agents": 12,
      "tasks": 10,
      "comments": 3,
      "comment_chars": 500,
      "runs": 0
    },
    "visibility": {
      "status_runs": false,
      "uuids": false
    },
    "errors": {
      "show_details": false,
      "show_debug_hint": true
    }
  },
  "actions": {
    "finalize": {
      "usage": "finalize ISSUE",
      "aliases": ["close-package"],
      "description": "close a package when all child items are already finished",
      "builtin": "finalize"
    },
    "sample": {
      "usage": "sample ARG",
      "aliases": ["demo"],
      "natural_aliases": ["run sample"],
      "description": "run the sample project action",
      "exec": ["./scripts/project-action", "sample"],
      "timeout": 120
    }
  },
  "intents": {
    "create_sample": {
      "action": "sample",
      "aliases": ["create sample task", "start sample research"],
      "require_tail": true,
      "min_tail_chars": 10
    }
  }
}
